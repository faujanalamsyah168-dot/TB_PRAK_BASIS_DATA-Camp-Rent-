# ============================================================
# DEPENDENCIES
# ============================================================
node_modules/
backend/node_modules/
frontend/node_modules/

# ============================================================
# ENVIRONMENT VARIABLES / SECRETS
# Tetap push file .env.example sebagai template
# ============================================================
.env
.env.*
!.env.example

backend/.env
backend/.env.*
!backend/.env.example

frontend/.env
frontend/.env.*
!frontend/.env.example

# ============================================================
# VITE / BUILD OUTPUT
# ============================================================
.vite/
frontend/.vite/
dist/
frontend/dist/
backend/dist/

# ============================================================
# CACHE / COVERAGE / TEMPORARY FILES
# ============================================================
.cache/
coverage/
tmp/
temp/
*.tmp
*.temp

# ============================================================
# LOG FILES
# ============================================================
*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*
lerna-debug.log*

# ============================================================
# EDITOR / IDE
# ============================================================
.vscode/
.idea/
*.code-workspace

# ============================================================
# OPERATING SYSTEM FILES
# ============================================================
.DS_Store
Thumbs.db
desktop.ini

# ============================================================
# OPTIONAL RUNTIME-GENERATED FILES
# Aktifkan jika folder upload berisi file yang diunggah pengguna
